#!/usr/bin/env python3

import subprocess as sp
from pathlib import Path
from datetime import datetime, timezone, timedelta
import logging
import argparse
import re

logging.basicConfig(
    level=logging.WARNING, format="%(asctime)s|%(levelname)s: %(message)s"
)
logger = logging.getLogger("zmx-prune")


def kill_session(name):
    sp.check_call(["zmx", "kill", name, "--force"])


def parse_time(value):
    if value.isdigit():
        return datetime.fromtimestamp(int(value), tz=timezone.utc)

    normalised = value.removesuffix("Z")
    try:
        parsed = datetime.fromisoformat(normalised)
    except ValueError:
        logger.warning(f"could not parse created time {value!r}")
        return None

    if parsed.tzinfo is None:
        return parsed.replace(tzinfo=timezone.utc)
    return parsed.astimezone(timezone.utc)


def list_sessions():
    output = sp.check_output(["zmx", "list"], stderr=sp.DEVNULL).decode().splitlines()
    for line in output:
        fields = {}
        for part in re.split(r"\s+", line.strip()):
            if "=" not in part:
                continue
            key, value = part.split("=", 1)
            fields[key] = value

        if not fields:
            continue

        name = fields.get("session_name") or fields.get("name")
        if fields.get("status") == "unreachable":
            logger.info(f"session {name} is unreachable; skipping")
            continue

        created = fields.get("created") or fields.get("created_at")
        if not name or not created:
            logger.warning(f"invalid zmx list output: {line}")
            continue

        parsed = parse_time(created)
        if parsed is None:
            continue

        yield name, parsed


if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("-f", "--force", action="store_true", default=False)
    parser.add_argument("-C", "--created", action="store_true", default=False,
                        help="Kept for compatibility; zmx exposes created time")
    parser.add_argument(
        "-c",
        "--cutoff",
        required=False,
        help="Cutoff time in days",
        type=int,
        default=5,
    )
    parser.add_argument("-v", "--verbose", action="count", default=0)
    args = parser.parse_args()

    if args.verbose == 1:
        logger.setLevel(logging.INFO)
    elif args.verbose > 1:
        logger.setLevel(logging.DEBUG)

    now = datetime.now(tz=timezone.utc)
    cutoff = now - timedelta(days=args.cutoff)

    logger.info(f"now:\t{now}")
    logger.info(f"cutoff:\t{cutoff}")

    to_prune = []

    for name, created in list_sessions():
        if created < cutoff:
            logger.info(
                f"session {name} created {created:%Y-%m-%d %H:%M:%S} pruning"
            )
            to_prune.append(name)
        else:
            logger.debug(
                f"session {name} created {created:%Y-%m-%d %H:%M:%S} not pruning"
            )

    if len(to_prune) == 0:
        logger.info("no sessions to prune found")
        exit(0)

    if not args.force:
        logger.warning("-f/--force not supplied; not pruning")
        exit(0)

    prune_dir = Path.home() / ".local" / "state" / "zmx" / "prunes"
    prune_dir.mkdir(exist_ok=True, parents=True)
    logger.info(f"using prune directory {prune_dir}")

    prune_fname = prune_dir / f"{now}.txt"
    assert not prune_fname.is_file()
    with prune_fname.open("w") as outfile:
        for prune in to_prune:
            kill_session(prune)
            print(prune, file=outfile)
