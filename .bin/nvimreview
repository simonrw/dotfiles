#!/usr/bin/env python3

import argparse
import os
import sys
import subprocess as sp
from pathlib import Path
from typing import NoReturn
from urllib.parse import urlparse
import re


# GitHub owner/repo -> local directory name, for repos where the names differ
REPO_ALIASES: dict[str, str] = {
    "localstack/localstack-core": "localstack/localstack",
}

_remote: str
_base: str


def zmx_session_name(*parts: str) -> str:
    raw = "-".join(parts)
    sanitised = re.sub(r"[^A-Za-z0-9_-]+", "-", raw)
    sanitised = re.sub(r"-+", "-", sanitised).strip("-")
    return sanitised or "default"


def die(msg: str) -> NoReturn:
    print(msg, file=sys.stderr)
    sys.exit(1)


def run(*cmd: str) -> None:
    sp.check_call(cmd)


def open_review() -> NoReturn:
    merge_base = sp.check_output(["git", "merge-base", f"{_remote}/{_base}", "HEAD"]).decode()
    run("git", "reset", "--soft", merge_base)
    os.execvp("nvim", ["nvim", "-c", ":G"])


def handle_pr_number(number: str) -> NoReturn:
    run("git", "fetch", _remote)
    run("gh", "pr", "checkout", number)
    open_review()


def handle_branch(branch: str) -> NoReturn:
    run("git", "fetch", _remote)

    # Check if local branch exists
    result = sp.run(
        ["git", "rev-parse", "--verify", branch],
        capture_output=True,
    )
    if result.returncode != 0:
        run("git", "checkout", "-b", branch, "--track", f"{_remote}/{branch}")
    else:
        run("git", "checkout", branch)
        run("git", "merge", "--ff-only", f"{_remote}/{branch}")

    open_review()


def session_exists(name: str) -> bool:
    result = sp.run(["zmx", "list", "--short"], capture_output=True, text=True)
    if result.returncode != 0:
        return False
    return name in result.stdout.splitlines()


def handle_url(url: str) -> NoReturn:
    parsed = urlparse(url)
    parts = parsed.path.strip("/").split("/")
    if len(parts) < 4 or parts[2] != "pull":
        die(f"error: cannot parse GitHub PR URL: {url}")

    owner_repo = f"{parts[0]}/{parts[1]}"
    pr_number = parts[3]

    local_suffix = REPO_ALIASES.get(owner_repo, owner_repo)

    # Find local path via listprojects
    result = sp.run(["listprojects", "-l"], capture_output=True, text=True, check=True)
    local_path: str | None = None
    for line in result.stdout.strip().splitlines():
        if line.rstrip("/").endswith(local_suffix):
            local_path = line.strip()
            break

    if not local_path:
        die(f"error: no local checkout found for {owner_repo}")

    # Derive zmx session name, matching tnew.
    p = Path(local_path)
    session_name = zmx_session_name(p.parent.name, p.name)

    if session_exists(session_name):
        run("zmx", "send", session_name, f"nvimreview {pr_number}\n")
        os.execvp("zmx", ["zmx", "attach", session_name])

    os.chdir(local_path)
    os.execvp("zmx", ["zmx", "attach", session_name, "nvimreview", pr_number])


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Review a PR in neovim with fugitive. "
        "Fetches the branch, soft-resets against the base branch, and opens nvim with :G.",
        epilog="examples:\n"
        "  nvimreview 1234                                        # checkout PR by number\n"
        "  nvimreview feature-branch                              # checkout branch by name\n"
        "  nvimreview https://github.com/owner/repo/pull/1234     # find local repo, open in a zmx session",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "target",
        help="PR number, branch name, or GitHub PR URL",
    )
    parser.add_argument(
        "-r", "--remote",
        default="origin",
        help="git remote to fetch from (default: origin)",
    )
    parser.add_argument(
        "-b", "--base",
        default=os.getenv("REVIEW_BASE", "main"),
        help="base branch to diff against (default: $REVIEW_BASE or 'main')",
    )
    args = parser.parse_args()

    # Make base/remote available to helper functions
    global _remote, _base
    _remote = args.remote
    _base = args.base

    target = args.target
    if target.startswith("https://github.com"):
        handle_url(target)
    elif target.isdigit():
        handle_pr_number(target)
    else:
        handle_branch(target)


if __name__ == "__main__":
    main()
