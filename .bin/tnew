#!/usr/bin/env python3


import subprocess as sp
from pathlib import Path
import argparse
import json
import os
import logging


logging.basicConfig(level=logging.WARNING)
logger = logging.getLogger("tnew")


HERDR_LAST_WS_FILE = Path(
    os.environ.get("HERDR_LAST_WS_FILE")
    or os.path.join(
        os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache")),
        "herdr",
        "last-workspace",
    )
)


def herdr_workspaces():
    """Return the herdr workspace list (list of dicts)."""
    out = sp.run(
        ["herdr", "workspace", "list"], check=True, stdout=sp.PIPE
    ).stdout.decode("utf8")
    data = json.loads(out)
    return data.get("result", data).get("workspaces", [])


def herdr_focused_id(workspaces):
    for ws in workspaces:
        if ws.get("focused"):
            return ws.get("workspace_id")
    return None


def herdr_record_last(workspaces):
    """Remember the currently-focused workspace so `tl` can jump back."""
    current = herdr_focused_id(workspaces)
    if current:
        HERDR_LAST_WS_FILE.parent.mkdir(parents=True, exist_ok=True)
        HERDR_LAST_WS_FILE.write_text(current + "\n")


def run_herdr_in_herdr(label, path):
    """Focus a workspace with this label, or create one for the given path."""
    workspaces = herdr_workspaces()
    herdr_record_last(workspaces)
    for ws in workspaces:
        if ws.get("label") == label:
            logger.debug(f"focusing existing workspace {label}")
            os.execvp("herdr", ["herdr", "workspace", "focus", ws["workspace_id"]])
    logger.debug(f"creating workspace {label}")
    os.execvp(
        "herdr",
        ["herdr", "workspace", "create", "--cwd", str(path), "--label", label, "--focus"],
    )


def list_sessions():
    try:
        sessions = run_tmux("ls", "-F", "#S")
    except sp.CalledProcessError:
        return []

    yield from sessions.split()


def session_exists(session_name):
    logger.debug(f"looking for session {session_name}")
    for session in list_sessions():
        if session_name == session:
            logger.debug(f"found session {session_name}")
            return True
    logger.debug(f"cannot find session {session_name}")
    return False


def attach_to_session(session_name, exec):
    logger.debug(f"attaching to session {session_name}")
    run_tmux("attach", "-t", session_name, exec=exec)


def create_session(session_name):
    logger.debug(f"creating new session {session_name}")
    run_tmux("new-session", "-d", "-s", session_name)


def switch_client(session_name, exec):
    logger.debug(f"switching to session {session_name}")
    run_tmux("switch-client", "-t", session_name, exec=exec)


def run_tmux(*args, exec=False):
    cmd = [
        "tmux",
    ] + list(args)
    logger.debug(f"running command: {cmd}")

    if exec:
        os.execvp(cmd[0], cmd)
    else:
        proc = sp.run(cmd, check=True, stdout=sp.PIPE)
        return proc.stdout.decode("utf8")


parser = argparse.ArgumentParser()
parser.add_argument("-p", "--path", type=Path, default=Path.cwd())
parser.add_argument("-v", "--verbose", action="count", default=0)
args = parser.parse_args()

if args.verbose == 1:
    logger.setLevel(logging.INFO)
elif args.verbose > 1:
    logger.setLevel(logging.DEBUG)

args.path.mkdir(exist_ok=True, parents=True)

tmux_name = f"{args.path.parent.name}/{args.path.name}".replace(".", "-").replace(":", "-")

if os.getenv("TMUX"):
    logger.debug("in tmux session")
    if session_exists(tmux_name):
        switch_client(tmux_name, exec=True)
    else:
        create_session(tmux_name)
        switch_client(tmux_name, exec=True)
else:
    logger.debug("in herdr pane")
    run_herdr_in_herdr(tmux_name, args.path)
