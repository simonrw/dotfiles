#!/usr/bin/env python3


from pathlib import Path
import argparse
import os
import logging
import re


logging.basicConfig(level=logging.WARNING)
logger = logging.getLogger("tnew")


def zmx_session_name(*parts: str) -> str:
    raw = "-".join(parts)
    sanitised = re.sub(r"[^A-Za-z0-9_-]+", "-", raw)
    sanitised = re.sub(r"-+", "-", sanitised).strip("-")
    return sanitised or "default"


parser = argparse.ArgumentParser()
parser.add_argument("-p", "--path", type=Path, default=Path.cwd())
parser.add_argument("-v", "--verbose", action="count", default=0)
parser.add_argument("command", nargs=argparse.REMAINDER)
args = parser.parse_args()

if args.verbose == 1:
    logger.setLevel(logging.INFO)
elif args.verbose > 1:
    logger.setLevel(logging.DEBUG)

args.path.mkdir(exist_ok=True, parents=True)

session_name = zmx_session_name(args.path.parent.name, args.path.name)
command = args.command
if command and command[0] == "--":
    command = command[1:]

os.chdir(args.path)
logger.debug(f"attaching to zmx session {session_name}")
os.execvp("zmx", ["zmx", "attach", session_name, *command])
