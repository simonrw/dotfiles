#!/bin/sh
#
# Attach or create a session named the same as the current directory.
# Works under tmux (sessions) and herdr (workspaces).

path_name="$(basename $(dirname ${PWD}))/$(basename ${PWD})"
session_name=${1-$path_name}

# herdr: focus a workspace with this label, or create one for the current dir.
if [ -n "${HERDR_PANE_ID:-}" ]; then
  . "$(dirname "$0")/herdr-lib.sh"
  existing="$(herdr_ws_by_label "$session_name")"
  if [ -n "$existing" ]; then
    herdr_focus "$existing"
  else
    herdr_record_last
    herdr workspace create --cwd "${PWD}" --label "$session_name" --focus
  fi
  exit 0
fi

not_in_tmux() {
  [ -z "$TMUX" ]
}

session_exists() {
  tmux list-sessions | sed -E 's/:.*$//' | grep -q "^$session_name$"
}

create_detached_session() {
  (TMUX='' tmux -2 new-session -Ad -s "$session_name")
}

create_if_needed_and_attach() {
  if not_in_tmux; then
    tmux -2 new-session -As "$session_name"
  else
    if ! session_exists; then
      create_detached_session
    fi
    tmux switch-client -t "$session_name"
  fi
}

create_if_needed_and_attach
