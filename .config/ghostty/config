macos-non-native-fullscreen = true
macos-titlebar-style = tabs
window-save-state = never
macos-option-as-alt = true
# add some window padding
window-padding-x = 8
window-padding-y = 6
confirm-close-surface = false
keybind = shift+enter=text:\n

font-style-italic = false
font-style-bold-italic = false
font-synthetic-style = "no-italic"
font-thicken = true
theme = dark:Catppuccin Mocha,light:Catppuccin Latte
cursor-style = block
cursor-style-blink = false
shell-integration = detect
shell-integration-features = no-cursor,ssh-terminfo,ssh-env,path
mouse-hide-while-typing = true
mouse-reporting = false

window-colorspace = display-p3
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true
split-preserve-zoom = navigation

# tmux-style prefix bindings. Ghostty owns windows, tabs, and splits; zmx owns
# session persistence.
keybind = ctrl+s>s=text:\x13
keybind = ctrl+s>c=new_tab
keybind = ctrl+s>ctrl+b=new_tab
keybind = chain=text:tat\n
keybind = ctrl+s>ctrl+p=previous_tab
keybind = ctrl+s>ctrl+n=next_tab
keybind = ctrl+s>p=previous_tab
keybind = ctrl+s>n=next_tab
keybind = ctrl+s>ctrl+j=last_tab
keybind = ctrl+s>ctrl+s=last_tab
keybind = ctrl+s>1=goto_tab:1
keybind = ctrl+s>2=goto_tab:2
keybind = ctrl+s>3=goto_tab:3
keybind = ctrl+s>4=goto_tab:4
keybind = ctrl+s>5=goto_tab:5
keybind = ctrl+s>6=goto_tab:6
keybind = ctrl+s>7=goto_tab:7
keybind = ctrl+s>8=goto_tab:8
keybind = ctrl+s>9=previous_tab
keybind = ctrl+s>0=next_tab
keybind = ctrl+s>comma=prompt_tab_title
keybind = ctrl+s>shift+comma=move_tab:-1
keybind = ctrl+s>shift+period=move_tab:1
keybind = ctrl+s>i=new_split:right
keybind = ctrl+s>shift+backslash=new_split:right
keybind = ctrl+s>minus=new_split:down
keybind = ctrl+s>h=goto_split:left
keybind = ctrl+s>j=goto_split:down
keybind = ctrl+s>k=goto_split:up
keybind = ctrl+s>l=goto_split:right
keybind = ctrl+s>shift+h=resize_split:left,30
keybind = ctrl+s>shift+j=resize_split:down,30
keybind = ctrl+s>shift+k=resize_split:up,30
keybind = ctrl+s>shift+l=resize_split:right,30
keybind = ctrl+s>z=toggle_split_zoom
keybind = ctrl+s>equal=equalize_splits
keybind = ctrl+s>x=close_surface
keybind = ctrl+s>shift+x=close_window
keybind = ctrl+s>r=reload_config
keybind = ctrl+s>slash=start_search
keybind = ctrl+s>page_up=scroll_page_up
keybind = ctrl+s>page_down=scroll_page_down
keybind = ctrl+s>home=scroll_to_top
keybind = ctrl+s>end=scroll_to_bottom
keybind = ctrl+s>u=new_split:down
keybind = chain=text:jjui\n
keybind = ctrl+s>o=new_split:down
keybind = chain=text:lazygit\n
keybind = ctrl+s>a=new_split:down
keybind = chain=text:listprojects\n
keybind = ctrl+s>f=new_split:down
keybind = chain=text:tmux-session-history\n
keybind = ctrl+s>shift+slash=toggle_command_palette

config-file = ?local.config

