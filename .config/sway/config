# Programs
set $terminal ghostty
set $browser helium
set $menu fuzzel
set $mod Mod4

# Input
input type:keyboard {
    xkb_layout us
    xkb_options caps:ctrl_modifier
}

input type:pointer {
    accel_profile flat
    pointer_accel -0.65
}

# Appearance
default_border pixel 2
gaps inner 5
gaps outer 10
client.focused #33ccff #33ccff #ffffff #00ff99 #33ccff
client.unfocused #595959 #595959 #ffffff #595959 #595959

# Autostart
exec waybar
exec swayidle -w

# Environment
exec_always {
    gsettings set org.gnome.desktop.interface cursor-size 24
}
exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP

# App launchers
bindsym Alt+Mod4+t exec $terminal
bindsym Alt+Mod4+c exec $browser
bindsym $mod+d exec $menu

# Window management
bindsym $mod+q kill
bindsym $mod+v floating toggle
bindsym $mod+f fullscreen
bindsym $mod+s layout toggle split

# Move focus with hjkl
bindsym $mod+h focus left
bindsym $mod+l focus right
bindsym $mod+k focus up
bindsym $mod+j focus down

# Move focus with arrows
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

# Move windows with hjkl
bindsym $mod+Shift+h move left
bindsym $mod+Shift+l move right
bindsym $mod+Shift+k move up
bindsym $mod+Shift+j move down

# Move windows with arrows
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Down move down

# Switch workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9

# Move to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9

# Scroll through workspaces
bindsym $mod+button4 workspace next
bindsym $mod+button5 workspace prev

# Move/resize with mouse
floating_modifier $mod normal
# Right-click to resize (tiling_drag handles this in sway)
tiling_drag enable
